# ============================================================
# Think Decision — Backend Environment Configuration
# ------------------------------------------------------------
# Cara pakai:
#   1. Salin file ini menjadi `.env` di folder backend/
#      (PowerShell:  Copy-Item .env.example .env)
#   2. Isi semua nilai yang bertanda <...>
#   3. JANGAN commit file .env ke git (sudah ada di .gitignore)
# ============================================================

# ---------- WAJIB DIISI ----------

# URL project Supabase kamu.
# Ambil dari: https://supabase.com/dashboard → pilih project
#   → Settings → Data API → "Project URL"
# Format: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=<https://xxxxxxxxxxxx.supabase.co>

# Service Role Key Supabase (BUKAN anon key!).
# Ambil dari: Settings → API Keys → "service_role" → Reveal.
# Key ini melewati semua Row Level Security — rahasiakan,
# hanya boleh ada di backend, jangan pernah taruh di frontend.
SUPABASE_SERVICE_KEY=<service-role-key-kamu>

# Secret untuk menandatangani JWT (token login).
# Isi dengan string acak panjang (min. 32 karakter).
# Cara generate (jalankan di terminal):
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Catatan: kalau nilai ini diganti, semua user harus login ulang.
JWT_SECRET=<string-acak-minimal-32-karakter>

# ---------- OPSIONAL (default sudah benar untuk development lokal) ----------

# Port HTTP backend. Default: 3000
PORT=3000

# Origin frontend yang diizinkan CORS.
# Harus sama persis dengan alamat tempat frontend dibuka.
CORS_ORIGIN=http://localhost:8000

# Mode aplikasi: development | production
# development = pesan error detail, cookie tidak perlu HTTPS
# production  = cookie Secure (butuh HTTPS), error disembunyikan
NODE_ENV=development

# Redis untuk caching. KOSONGKAN kalau tidak punya Redis —
# backend tetap jalan normal, hanya caching yang nonaktif.
# Contoh kalau ada Redis lokal: redis://localhost:6379
REDIS_URL=
